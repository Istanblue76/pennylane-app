# ── Cloudinary (Ücretsiz görsel depolama) ──────────────────────────────────────
# https://cloudinary.com/users/new/register_default adresinden ücretsiz hesap açın
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── MongoDB Atlas (Ücretsiz veritabanı) ────────────────────────────────────────
# https://www.mongodb.com/cloud/atlas/register adresinden ücretsiz hesap açın
# → Proje oluştur → M0 Sandbox seç (ücretsiz) → Bağlantı dizesini al
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# ── Admin Girişi ───────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=antigravity123

# ── Sunucu Portu (Render otomatik ayarlar, değiştirme) ─────────────────────────
PORT=5000
